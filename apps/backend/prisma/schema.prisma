generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  libraryItems LibraryItem[]
  reviews      Review[]
  comments     Comment[]
  reels        Reel[]

  @@map("users")
}

model LibraryItem {
  id        String   @id @default(cuid())
  userId    String
  gameId    String
  status    String   @default("played") // played, playing, wishlist, completed
  rating    Int?     @db.SmallInt
  playtime  Int?     // in minutes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@map("library_items")
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  gameId    String
  title     String
  content   String   @db.Text
  rating    Int      @db.SmallInt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  author   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments Comment[]

  @@map("reviews")
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  reviewId  String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  author User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  review Review  @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model News {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  gameId      String?
  imageUrl    String?
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("news")
}

model Reel {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?  @db.Text
  videoUrl    String
  gameId      String?
  category    String?  // gameplay, trailer, tips, nostalgia, funny
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  author User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reels")
}

model Wallpaper {
  id         String   @id @default(cuid())
  title      String
  imageUrl   String
  gameId     String?
  category   String?  // mobile, desktop, console
  resolution String?  // 1920x1080, 2560x1440, etc.
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("wallpapers")
}
